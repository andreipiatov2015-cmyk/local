[Unit]
Description=reboot-server (Flask, порт 8084) — вспомогательный сервис
After=network.target

[Service]
Type=simple
# Без User= (root) — см. пояснение в live-server.service: так работает
# сейчас restart_astra.sh, менять модель привилегий здесь не будем.
WorkingDirectory=/var/www/reboot
ExecStart=/usr/bin/python3 /var/www/reboot/server.py
Restart=on-failure
RestartSec=5
StandardOutput=append:/var/log/reboot-server.log
StandardError=append:/var/log/reboot-server.log

[Install]
WantedBy=multi-user.target
