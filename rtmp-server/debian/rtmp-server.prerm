#!/bin/sh
# RTMP-server не имеет собственного systemd-юнита (это GUI-приложение,
# запускаемое вручную) — здесь нечего останавливать. Юниты сайта
# (nginx-rtmp/live-server/reboot-server) НИКОГДА не трогаются здесь —
# они принадлежат сайту, а не этому пакету, и должны пережить его удаление.
set -e
exit 0
