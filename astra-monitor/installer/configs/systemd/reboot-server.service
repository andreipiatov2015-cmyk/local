[Unit]
Description=Astra Monitor - Reboot Server (Flask)
After=network.target nginx-custom.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/reboot
Environment="PATH=/var/www/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin"
Environment="FLASK_APP=server.py"
ExecStart=/var/www/.venv/bin/python3 /var/www/reboot/server.py
Restart=always
RestartSec=10
StandardOutput=append:/var/www/logs/reboot-server.log
StandardError=append:/var/www/logs/reboot-server-error.log

[Install]
WantedBy=multi-user.target